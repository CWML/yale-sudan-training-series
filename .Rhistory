# ── Install/load required packages ──────────────────────────────────────
pkgs <- c("tidyverse", "lubridate", "stringr")
install.packages(setdiff(pkgs, rownames(installed.packages())), repos = "https://cloud.r-project.org")
library(tidyverse)
library(lubridate)
library(stringr)
# ── 1. Parameters ──────────────────────────────────────────────────────
set.seed(20260507)           # for reproducibility
n_cases   <- 2000            # change to any size you like
year_tag  <- 2025            # surveillance year
states <- c("Khartoum", "Kassala", "Gezira", "Blue Nile",
"North Darfur", "South Darfur", "Red Sea", "White Nile")
state_prob <- c(0.15, 0.12, 0.14, 0.10, 0.16, 0.13, 0.10, 0.10)  # tweak as needed
# ── 2. Generate core variables ─────────────────────────────────────────
# Date sampling with higher weight for Aug–Oct (post-rainy-season peak)
all_days <- seq.Date(as.Date(sprintf("%s-01-01", year_tag)),
as.Date(sprintf("%s-12-31", year_tag)),
by = "day")
month_wt <- ifelse(month(all_days) %in% 8:10, 3, 1)
linelist <- tibble(
case_id = sprintf("SDN%05d", 1:n_cases),
date_onset = sample(all_days, size = n_cases, replace = TRUE, prob = month_wt),
state  = sample(states, size = n_cases, replace = TRUE, prob = state_prob),
sex    = sample(c("Male", "Female"), size = n_cases, replace = TRUE),
age    = sample(0:80, size = n_cases, replace = TRUE,
prob = dpois(0:80, lambda = 18) + 1e-2),   # skew young
species = sample(c("P. falciparum", "P. vivax"),
size = n_cases, replace = TRUE, prob = c(0.8, 0.2)),
outcome = sample(c("recovered", "hospitalised", "death"),
size = n_cases, replace = TRUE, prob = c(0.90, 0.07, 0.03)),
treated = sample(c("ACT", "Chloroquine", "None"),
size = n_cases, replace = TRUE, prob = c(0.75, 0.15, 0.10)),
test_type = sample(c("RDT", "Microscopy"),
size = n_cases, replace = TRUE, prob = c(0.7, 0.3))
)
# ── 3. Add very rough geo-points per state (for mapping demos) ──────────
state_centroids <- tribble(
~state,          ~lat,  ~lon,
"Khartoum",      15.6,  32.5,
"Kassala",       15.3,  36.4,
"Gezira",        14.4,  33.5,
"Blue Nile",     11.7,  34.3,
"North Darfur",  16.3,  25.8,
"South Darfur",  11.5,  25.0,
"Red Sea",       19.6,  37.2,
"White Nile",    14.6,  32.5
)
linelist <- linelist %>%
left_join(state_centroids, by = "state") %>%
mutate(
# jitter around each centroid so points are not identical
lon = lon + rnorm(n(), 0, 0.3),
lat = lat + rnorm(n(), 0, 0.3)
)
# ── 4. Ensure project folders exist & write files ───────────────────────
dirs <- c("raw_data", "processed_data")
purrr::walk(dirs, ~ dir.create(.x, showWarnings = FALSE))
write_csv(linelist,  file.path("raw_data",      "malaria_linelist_2025_sudan.csv"))
saveRDS(linelist,    file.path("processed_data","malaria_linelist_2025_sudan.rds"))
# ── 5. Quick peek ───────────────────────────────────────────────────────
glimpse(linelist)
View(linelist)
