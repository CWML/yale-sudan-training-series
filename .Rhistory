library(dplyr)
library(ggplot2)
library(sf)
library(lubridate)  # only if you want epiweek, etc.
# ── 1. Have these objects in memory ────────────────────────────────────
# sudan_adm1   ← the GADM polygons you just downloaded
# dengue_ll    ← your synthetic line list with a 'state' column
# ── 2. Quick check: do the names line up? ───────────────────────────────
sort(unique(dengue_ll$state))
sort(unique(sudan_adm1$NAME_1))
# If you see spelling differences, fix them here. Example:
name_key <- c("Gezira" = "Al Jazirah")   # add more pairs if needed
dengue_ll <- dengue_ll %>%
mutate(state = recode(state, !!!name_key))
# ── 3. Aggregate to state level ─────────────────────────────────────────
dengue_counts <- dengue_ll %>%
count(state, name = "n_cases")
# ── 4. Join counts onto polygons ────────────────────────────────────────
map_df <- sudan_adm1 %>%
mutate(state = NAME_1) %>%
left_join(dengue_counts, by = "state") %>%
replace_na(list(n_cases = 0))        # states with zero cases
# ── 5. Choropleth map ───────────────────────────────────────────────────
ggplot(map_df) +
geom_sf(aes(fill = n_cases), colour = "grey40", linewidth = 0.3) +
scale_fill_viridis_c(option = "plasma", direction = -1) +
labs(title = "Synthetic Dengue Cases per State, Sudan 2025",
fill = "Cases") +
theme_minimal()
# ── 6. Dot map overlay (optional) ──────────────────────────────────────
ggplot() +
geom_sf(data = sudan_adm1, fill = NA, colour = "grey50") +
geom_point(data = dengue_ll,
aes(x = lon, y = lat, colour = severity),
alpha = 0.6, size = 1.5) +
coord_sf() +
scale_colour_brewer(palette = "Set1") +
labs(title = "Synthetic Dengue Cases in Sudan (2025)",
colour = "Severity") +
theme_minimal()
View(cholera_ll)
View(dengue_ll)
