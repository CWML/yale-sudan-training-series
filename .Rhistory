# ------------------------------------------------------------
# add_symptoms(): append yes/no/NA symptom columns
# ------------------------------------------------------------
add_symptoms <- function(data, disease) {
set.seed(1)                       # reproducible NA pattern
yes_no_na <- function(n, p_yes, p_na = 0.05) {
p_no <- 1 - p_yes - p_na
sample(c("yes", "no", NA_character_),
n, replace = TRUE,
prob = c(p_yes, p_no, p_na))
}
n <- nrow(data)
if (disease == "malaria") {
data <- data %>%
mutate(
fever       = yes_no_na(n, 0.92),
chills      = yes_no_na(n, 0.75),
headache    = yes_no_na(n, 0.65),
anaemia     = yes_no_na(n, 0.20),
convulsions = yes_no_na(n, 0.04)
)
} else if (disease == "cholera") {
data <- data %>%
mutate(
watery_diarrhoea  = yes_no_na(n, 0.97, 0.02),
vomiting          = yes_no_na(n, 0.80),
leg_cramps        = yes_no_na(n, 0.55),
dehydration_signs = yes_no_na(n, 0.45),
fever             = yes_no_na(n, 0.15)
)
} else if (disease == "dengue") {
data <- data %>%
mutate(
fever            = yes_no_na(n, 0.95),
retroorbital_pain= yes_no_na(n, 0.70),
rash             = yes_no_na(n, 0.50),
myalgia          = yes_no_na(n, 0.80),
bleeding_signs   = yes_no_na(n, 0.08)
)
} else {
stop("Unknown disease keyword.")
}
data
}
library(tidyverse)
# -- Append symptoms ----------------------------------------------------
malaria_ll <- add_symptoms(malaria_ll, "malaria")
library(tidyverse)
# -- Append symptoms ----------------------------------------------------
malaria_ll <- add_symptoms(malaria_linelist, "malaria")
cholera_ll <- add_symptoms(cholera_ll, "cholera")
dengue_ll  <- add_symptoms(dengue_ll,  "dengue")
# -- Save back ----------------------------------------------------------
write_csv(malaria_ll, "raw_data/malaria_linelist_2025_sudan.csv")
write_csv(cholera_ll, "raw_data/cholera_linelist_2025_sudan.csv")
write_csv(dengue_ll,  "raw_data/dengue_linelist_2025_sudan.csv")
View(malaria_linelist)
