# ---------- Packages & folders ----------
pkgs <- c("tidyverse", "lubridate")
install.packages(setdiff(pkgs, rownames(installed.packages())), repos = "https://cloud.r-project.org")
library(tidyverse); library(lubridate)
dir.create("raw_data",      showWarnings = FALSE)
dir.create("processed_data",showWarnings = FALSE)
# ---------- Parameters ----------
set.seed(20260507)
n_cases  <- 2000
year_tag <- 2025
states <- c("Khartoum","Kassala","Gezira","Blue Nile",
"North Darfur","South Darfur","Red Sea","White Nile")
state_prob <- c(0.22,0.15,0.18,0.08,0.08,0.12,0.05,0.12)  # cholera often clusters along Nile
# ---------- Date sampling – rainy season spike (Jun–Sep in Sudan) ----------
all_days <- seq(as.Date(sprintf("%s-01-01",year_tag)),
as.Date(sprintf("%s-12-31",year_tag)), by="day")
month_wt <- ifelse(month(all_days) %in% 6:9, 4, 1)   # heavy weighting for peak flooding months
# ---------- Build line list ----------
cholera_ll <- tibble(
case_id   = sprintf("CHL%05d", 1:n_cases),
date_onset= sample(all_days, n_cases, TRUE, month_wt),
state     = sample(states, n_cases, TRUE, state_prob),
sex       = sample(c("Male","Female"), n_cases, TRUE),
age       = sample(0:90, n_cases, TRUE, dpois(0:90, lambda = 20)+1e-2),
dehydration = sample(c("none","moderate","severe"), n_cases, TRUE,
prob = c(0.25,0.55,0.20)),
outcome   = sample(c("recovered","hospitalised","death"), n_cases, TRUE,
prob = c(0.85,0.12,0.03)),
treatment = sample(c("ORS only","ORS+IV","none"), n_cases, TRUE,
prob = c(0.6,0.35,0.05)),
source_water = sample(c("piped","well","river","truck"), n_cases, TRUE,
prob = c(0.4,0.25,0.25,0.10))
)
# ---------- Add approximate centroids & jitter ----------
centroids <- tribble(
~state,          ~lat,  ~lon,
"Khartoum",      15.6,  32.5,
"Kassala",       15.3,  36.4,
"Gezira",        14.4,  33.5,
"Blue Nile",     11.7,  34.3,
"North Darfur",  16.3,  25.8,
"South Darfur",  11.5,  25.0,
"Red Sea",       19.6,  37.2,
"White Nile",    14.6,  32.5
)
cholera_ll <- cholera_ll %>%
left_join(centroids, by="state") %>%
mutate(
lon = lon + rnorm(n(),0,0.25),
lat = lat + rnorm(n(),0,0.25)
)
# ---------- Save ----------
write_csv(cholera_ll, "raw_data/cholera_linelist_2025_sudan.csv")
saveRDS(cholera_ll,  "processed_data/cholera_linelist_2025_sudan.rds")
View(cholera_ll)
# ── Packages ────────────────────────────────────────────────────────────
pkgs <- c("tidyverse", "lubridate")
install.packages(setdiff(pkgs, rownames(installed.packages())),
repos = "https://cloud.r-project.org")
library(tidyverse)
library(lubridate)
# ── Ensure project folders exist ────────────────────────────────────────
dir.create("raw_data",      showWarnings = FALSE)
dir.create("processed_data",showWarnings = FALSE)
# ── Parameters ──────────────────────────────────────────────────────────
set.seed(20260509)
n_cases  <- 2000            # adjust as needed
year_tag <- 2025
states <- c("Khartoum", "Kassala", "Gezira", "Blue Nile",
"North Darfur", "South Darfur", "Red Sea", "White Nile")
state_prob <- c(0.25, 0.15, 0.15, 0.10, 0.08, 0.12, 0.05, 0.10)
# Dengue tends to cluster in Khartoum and Kassala but occurs country-wide
# ── Seasonality: peak Jul–Nov (post-rains) ──────────────────────────────
all_days <- seq.Date(as.Date(sprintf("%s-01-01", year_tag)),
as.Date(sprintf("%s-12-31", year_tag)),
by = "day")
month_wt <- ifelse(month(all_days) %in% 7:11, 4, 1)
# ── Build the line list ────────────────────────────────────────────────
dengue_ll <- tibble(
case_id    = sprintf("DNG%05d", 1:n_cases),
date_onset = sample(all_days, n_cases, TRUE, month_wt),
state      = sample(states, n_cases, TRUE, state_prob),
sex        = sample(c("Male", "Female"), n_cases, TRUE),
age        = sample(0:80, n_cases, TRUE,
dpois(0:80, lambda = 18) + 1e-2),          # skew young
serotype   = sample(paste0("DENV-", 1:4), n_cases, TRUE,
prob = c(0.35, 0.30, 0.20, 0.15)),
severity   = sample(c("DF",  "DHF", "DSS"), n_cases, TRUE,
prob = c(0.80, 0.17, 0.03)),
outcome    = sample(c("recovered", "hospitalised", "death"),
n_cases, TRUE, prob = c(0.92, 0.07, 0.01)),
days_hosp  = ifelse(runif(n_cases) < 0.07,
sample(1:14, n_cases, TRUE), 0)
)
# ── Add crude centroids & jitter for mapping ────────────────────────────
centroids <- tribble(
~state,          ~lat,  ~lon,
"Khartoum",      15.6,  32.5,
"Kassala",       15.3,  36.4,
"Gezira",        14.4,  33.5,
"Blue Nile",     11.7,  34.3,
"North Darfur",  16.3,  25.8,
"South Darfur",  11.5,  25.0,
"Red Sea",       19.6,  37.2,
"White Nile",    14.6,  32.5
)
dengue_ll <- dengue_ll %>%
left_join(centroids, by = "state") %>%
mutate(
lon = lon + rnorm(n(), 0, 0.25),
lat = lat + rnorm(n(), 0, 0.25)
)
# ── Save files ──────────────────────────────────────────────────────────
write_csv(dengue_ll,
"raw_data/dengue_linelist_2025_sudan.csv")
saveRDS(dengue_ll,
"processed_data/dengue_linelist_2025_sudan.rds")
# ── Quick peek ──────────────────────────────────────────────────────────
glimpse(dengue_ll)
View(dengue_ll)
View(malaria_linelist)
